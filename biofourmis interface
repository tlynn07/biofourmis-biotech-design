function showPage(pageId) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  const page = document.getElementById('page-' + pageId);
  if (page) page.classList.add('active');

  // Active nav item (only in current portal's sidebar)
  const activeSidebar = document.getElementById(currentPortal === 'doctor' ? 'doctorSidebar' : 'patientSidebar');
  activeSidebar?.querySelectorAll('.nav-item').forEach(n => {
    n.classList.toggle('active', n.dataset.page === pageId);
  });

  // Lazy inits
  if (pageId === 'dp-trends') buildTrendCharts(document.getElementById('trendsPatientSelect')?.value || activePatientId);
  if (pageId === 'pp-map') setTimeout(initMap, 50);
  if (pageId === 'pp-health') updateAISuggestions();
}

function switchPortal(portal) {
  currentPortal = portal;

  // Toggle portal buttons
  document.querySelectorAll('.portal-btn').forEach(btn => {
    btn.classList.toggle('active', btn.dataset.portal === portal);
  });

  // Toggle sidebars
  document.getElementById('doctorSidebar').classList.toggle('sidebar-hidden', portal !== 'doctor');
  document.getElementById('patientSidebar').classList.toggle('sidebar-hidden', portal !== 'patient');

  // Update topbar user info
  const avatar = document.getElementById('topbarAvatar');
  const name   = document.getElementById('topbarName');
  const role   = document.getElementById('topbarRole');
  if (portal === 'doctor') {
    if (avatar) avatar.textContent = 'DR';
    if (name)   name.textContent   = 'Dr. Reynolds';
    if (role)   role.textContent   = 'Chief Medical Officer';
    showPage('dp-monitor');
  } else {
    if (avatar) avatar.textContent = 'ML';
    if (name)   name.textContent   = 'Maria Lopez';
    if (role)   role.textContent   = 'Patient · P-001';
    showPage('pp-vitals');
  }
}

