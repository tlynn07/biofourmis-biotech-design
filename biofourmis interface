/* ===========================  AI SUGGESTIONS  =========================== */
function updateAISuggestions() {
  const container = document.getElementById('aiSuggestions');
  if (!container || !Object.keys(currentVitals).length) return;

  const pt = PATIENTS[activePatientId];
  const v  = currentVitals;
  const suggestions = [];

  if (v.heartRate > 100)
    suggestions.push({ type: 'ai-critical', title: 'Tachycardia Detected', detail: `Resting heart rate of ${v.heartRate} bpm exceeds 100 bpm threshold. Biosensor data shows this is a recurring pattern — particularly in morning hours. Consider ECG follow-up and reviewing Metoprolol dosage.` });
  else if (v.heartRate > 90)
    suggestions.push({ type: 'ai-warning', title: 'Mildly Elevated Resting HR', detail: `Heart rate averaging ${v.heartRate} bpm. While not tachycardic, this is above optimal resting range for your age. Practice deep-breathing exercises before sleep.` });
  else
    suggestions.push({ type: 'ai-positive', title: 'Heart Rate Within Target', detail: `Current HR of ${v.heartRate} bpm is within the normal range. Continue current medication regimen and activity level.` });

  if (v.systolic > 140 || v.diastolic > 90)
    suggestions.push({ type: 'ai-critical', title: 'Hypertensive Reading', detail: `Blood pressure ${v.systolic}/${v.diastolic} mmHg exceeds Stage 1 hypertension threshold. Limit sodium intake, avoid caffeine, and contact your doctor if it exceeds 160/100 mmHg.` });
  else if (v.systolic > 130)
    suggestions.push({ type: 'ai-warning', title: 'Elevated Blood Pressure', detail: `BP ${v.systolic}/${v.diastolic} mmHg is in the pre-hypertensive range. Monitor closely throughout the day and note any symptoms.` });

  if (v.spo2 < 94)
    suggestions.push({ type: 'ai-critical', title: 'Low Blood Oxygen (SpO₂)', detail: `SpO₂ at ${v.spo2}% is below the safe threshold of 94%. Take slow, deep breaths. If below 92%, seek immediate medical attention.` });
  else if (v.spo2 < 96)
    suggestions.push({ type: 'ai-warning', title: 'SpO₂ Slightly Below Optimal', detail: `Oxygen saturation at ${v.spo2}%. This can occur due to shallow breathing or mild congestion. Try deep breathing exercises.` });

  if (v.glucose > 180)
    suggestions.push({ type: 'ai-critical', title: 'High Blood Glucose', detail: `Glucose level of ${v.glucose} mg/dL indicates hyperglycemia. Ensure Metformin dosing is on schedule and avoid high-carbohydrate foods. Hydrate well.` });
  else if (v.glucose > 140)
    suggestions.push({ type: 'ai-warning', title: 'Blood Glucose Above Target', detail: `Glucose at ${v.glucose} mg/dL is above your target range of 70–140 mg/dL. Consider a 15-minute light walk to help lower levels.` });

  if (suggestions.length === 0)
    suggestions.push({ type: 'ai-positive', title: 'All Vitals in Normal Range', detail: 'Your biosensor readings are currently within expected parameters. Continue your current care plan and medications as prescribed.' });

  container.innerHTML = suggestions.map(s => `
    <div class="ai-card ${s.type}">
      <p class="ai-card-title">${s.title}</p>
      <p class="ai-card-detail">${s.detail}</p>
    </div>
  `).join('');
}

