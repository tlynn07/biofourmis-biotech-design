/* ===========================  TRENDS CHARTS  =========================== */
function generateTrendData(patientId) {
  const pt = PATIENTS[patientId];
  const hours = Array.from({ length: 24 }, (_, i) => {
    const h = (new Date().getHours() - 23 + i + 24) % 24;
    return `${h.toString().padStart(2,'0')}:00`;
  });

  const gen = (cfg, hasSpikeAt = []) => hours.map((_, i) => {
    const isSpike = hasSpikeAt.includes(i);
    return getRandVital(cfg, isSpike);
  });

  return {
    labels: hours,
    heartRate: gen(pt.vitals.heartRate, [5, 6, 7]),
    systolic:  gen(pt.vitals.systolic,  [6, 7, 8]),
    diastolic: gen(pt.vitals.diastolic, [6, 7]),
    spo2:      gen(pt.vitals.spo2,      [1, 2]),
    respRate:  gen(pt.vitals.respRate,  []),
  };
}

function buildTrendCharts(patientId) {
  // Destroy existing
  Object.values(trendCharts).forEach(c => c.destroy());
  trendCharts = {};

  const data = generateTrendData(patientId);
  const tooltip = {
    backgroundColor: '#1f2937', titleColor: '#f9fafb',
    bodyColor: '#d1d5db', padding: 10, cornerRadius: 8,
  };
  const gridY = { color: '#f3f4f6', drawBorder: false };
  const gridX = { display: false };
  const tickStyle = { color: '#9ca3af', font: { size: 10 } };

  trendCharts.hr = new Chart(document.getElementById('hrTrendChart'), {
    type: 'line',
    data: {
      labels: data.labels,
      datasets: [{
        label: 'Heart Rate (bpm)',
        data: data.heartRate,
        borderColor: '#dc2626', backgroundColor: 'rgba(220,38,38,0.07)',
        borderWidth: 2, tension: 0.4, pointRadius: 2, fill: true,
        pointBackgroundColor: data.heartRate.map(v => v > PATIENTS[patientId].vitals.heartRate.normal[1] ? '#dc2626' : 'transparent'),
        pointRadius: data.heartRate.map(v => v > PATIENTS[patientId].vitals.heartRate.normal[1] ? 5 : 0),
      }]
    },
    options: { responsive:true, maintainAspectRatio:false, plugins:{ legend:{display:false}, tooltip },
      scales: { x:{ grid:gridX, ticks:{...tickStyle, maxTicksLimit:8} }, y:{ grid:gridY, ticks:{...tickStyle, maxTicksLimit:5} } } }
  });

  trendCharts.bp = new Chart(document.getElementById('bpTrendChart'), {
    type: 'line',
    data: {
      labels: data.labels,
      datasets: [
        { label: 'Systolic',  data: data.systolic,  borderColor:'#dc2626', backgroundColor:'rgba(220,38,38,.05)', borderWidth:2, tension:0.4, pointRadius:2, fill:false },
        { label: 'Diastolic', data: data.diastolic, borderColor:'#f97316', backgroundColor:'rgba(249,115,22,.05)', borderWidth:2, tension:0.4, pointRadius:2, fill:false },
      ]
    },
    options: { responsive:true, maintainAspectRatio:false, plugins:{ legend:{display:false}, tooltip },
      scales: { x:{ grid:gridX, ticks:{...tickStyle, maxTicksLimit:8} }, y:{ grid:gridY, ticks:{...tickStyle, maxTicksLimit:5} } } }
  });

  trendCharts.spo2 = new Chart(document.getElementById('spo2TrendChart'), {
    type: 'line',
    data: {
      labels: data.labels,
      datasets: [
        { label: 'SpO₂ (%)', data: data.spo2, borderColor:'#6366f1', backgroundColor:'transparent', borderWidth:2, tension:0.4, pointRadius:2 },
        { label: 'Resp. Rate (/min)', data: data.respRate, borderColor:'#0ea5e9', backgroundColor:'transparent', borderWidth:2, tension:0.4, pointRadius:2 },
      ]
    },
    options: { responsive:true, maintainAspectRatio:false, plugins:{ legend:{display:false}, tooltip },
      scales: { x:{ grid:gridX, ticks:{...tickStyle, maxTicksLimit:8} }, y:{ grid:gridY, ticks:{...tickStyle, maxTicksLimit:5} } } }
  });

  renderEvents(data, patientId);
}

function renderEvents(data, patientId) {
  const pt = PATIENTS[patientId];
  const list = document.getElementById('eventsList');
  if (!list) return;

  const events = [];
  data.heartRate.forEach((v, i) => {
    if (v > pt.vitals.heartRate.normal[1])
      events.push({ type: 'ev-critical', time: data.labels[i], title: `HR Spike: ${v} bpm`, detail: `Normal: ${pt.vitals.heartRate.normal[0]}–${pt.vitals.heartRate.normal[1]} bpm` });
    else if (v < pt.vitals.heartRate.normal[0])
      events.push({ type: 'ev-warning', time: data.labels[i], title: `Bradycardia: ${v} bpm`, detail: `Heart rate below 60 bpm` });
  });
  data.systolic.forEach((v, i) => {
    if (v > pt.vitals.systolic.normal[1])
      events.push({ type: 'ev-critical', time: data.labels[i], title: `BP Spike: ${v}/${data.diastolic[i]} mmHg`, detail: `Hypertensive reading detected` });
  });
  data.spo2.forEach((v, i) => {
    if (v < pt.vitals.spo2.normal[0])
      events.push({ type: 'ev-warning', time: data.labels[i], title: `Low SpO₂: ${v}%`, detail: `Below safe threshold of ${pt.vitals.spo2.normal[0]}%` });
  });

  events.sort((a, b) => a.time.localeCompare(b.time));

  if (events.length === 0) {
    list.innerHTML = `<li style="font-size:.82rem;color:#9ca3af;padding:12px 0;text-align:center">No anomalies detected in the last 24 hours.</li>`;
    return;
  }
  list.innerHTML = events.map(e => `
    <li class="event-item ${e.type}">
      <p class="event-time">${e.time}</p>
      <p class="event-title">${e.title}</p>
      <p class="event-detail">${e.detail}</p>
    </li>
  `).join('');
}

